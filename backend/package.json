{
  "name": "task-manager-backend",
  "version": "1.0.0",
  "description": "API pour gestionnaire de tâches",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --detectOpenHandles",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "node tests/e2e/selenium.test.js"
  },

  "jest": {
    "testMatch": ["**/tests/**/*.test.js"]
  },

  "keywords": [
    "task-manager",
    "api",
    "express"
  ],
  "author": "ESGI Students",
  "license": "MIT",

  "jest": {
    "testMatch": ["/tests//*.test.js"]
  },

  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^8.57.1",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}